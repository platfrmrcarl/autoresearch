      "Bash(tree:*)",
      "Bash(find:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git pull)",
      "Bash(git fetch:*)",
      "Bash(git stash:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(uv:*)",
      "Bash(uvx:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(black:*)",
      "Bash(isort:*)",
      "Bash(jupyter:*)",
      "Bash(npm run *)",
      "Bash(git *)",
      "Bash(docker *)",
      "Bash(gcloud *)",
      "Bash(stripe *)",
      "Edit(*)",
      "Read(*)",
      "Write(*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(git merge:*)",
      "Bash(pip install:*)",
      "Bash(uv add:*)"
