{
  "permissions": {
    "allow": [
      "Read", "Edit", "Write", "Glob", "Grep", "WebFetch", "WebSearch",
      "Bash(ls:*)", "Bash(cat:*)", "Bash(pwd)", "Bash(echo:*)", "Bash(which:*)",
      "Bash(tree:*)", "Bash(find:*)", "Bash(head:*)", "Bash(tail:*)",
      "Bash(git status)", "Bash(git diff:*)", "Bash(git log:*)",
      "Bash(git branch:*)", "Bash(git add:*)", "Bash(git commit:*)",
      "Bash(git checkout:*)", "Bash(git switch:*)", "Bash(git pull)",
      "Bash(git fetch:*)", "Bash(git stash:*)",
      "Bash(python:*)", "Bash(python3:*)", "Bash(pip:*)", "Bash(pip3:*)",
      "Bash(uv:*)", "Bash(uvx:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)", "Bash(mypy:*)", "Bash(black:*)", "Bash(isort:*)",
      "Bash(jupyter:*)"
    ],
    "ask": [
      "Bash(git push:*)", "Bash(git reset:*)", "Bash(git rebase:*)", "Bash(git merge:*)",
      "Bash(pip install:*)", "Bash(uv add:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)", "Bash(sudo:*)",
      "Bash(git push --force:*)", "Bash(git push -f:*)", "Bash(git reset --hard:*)",
      "Read(./.env)", "Read(./.env.*)", "Read(./**/.env)", "Read(./**/.env.*)",
      "Read(./**/serviceAccountKey.json)", "Read(./**/*.pem)", "Read(./**/*.key)"
    ]
  }
}
