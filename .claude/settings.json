      "Bash(sudo:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./**/serviceAccountKey.json)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Bash(rm -rf *)",
      "Bash(gcloud * delete *)"
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "stripe@claude-plugins-official": true
  }
